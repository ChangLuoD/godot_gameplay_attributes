<?xml version="1.0" encoding="UTF-8" ?>
<class name="AttributeContainer" inherits="Node" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		包含 [AttributeSet] 并管理 [AttributeBase] 和 [AttributeBuff] 对象。
	</brief_description>
	<description>
		此类用于管理 [AttributeBase] 和 [AttributeBuff] 对象。

		你可以使用此节点添加、移除和查找属性和增益效果。
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="add_attribute">
			<return type="void" />
			<param index="0" name="p_attribute" type="AttributeBase" />
			<description>
				向容器添加一个属性。
			</description>
		</method>
		<method name="apply_buff">
			<return type="void" />
			<param index="0" name="p_buff" type="AttributeBuff" />
			<description>
				将增益效果应用到正确的属性上。
			</description>
		</method>
		<method name="find" qualifiers="const">
			<return type="RuntimeAttribute" />
			<param index="0" name="p_predicate" type="Callable" />
			<description>
				使用谓词查找 [RuntimeAttribute]。
			</description>
		</method>
		<method name="find_buffed_value" qualifiers="const">
			<return type="float" />
			<param index="0" name="p_predicate" type="Callable" />
			<description>
				使用谓词查找属性的增益值。
			</description>
		</method>
		<method name="find_value" qualifiers="const">
			<return type="float" />
			<param index="0" name="p_predicate" type="Callable" />
			<description>
				使用谓词查找属性的值。
			</description>
		</method>
		<method name="get_attribute_buffed_value_by_name" qualifiers="const">
			<return type="float" />
			<param index="0" name="p_name" type="String" />
			<description>
				通过名称获取属性的增益值。
				[b]注意：[/b] 如果一个属性由多个其他属性派生，并且某个增益效果重载了 [method AttributeBuff._operate]，增益值将不能反映真实值。使用 [method find_buffed_value] 方法来获取真实值。
			</description>
		</method>
		<method name="get_attribute_by_name" qualifiers="const">
			<return type="RuntimeAttribute" />
			<param index="0" name="p_name" type="String" />
			<description>
				通过名称获取属性。
			</description>
		</method>
		<method name="get_attribute_value_by_name" qualifiers="const">
			<return type="float" />
			<param index="0" name="p_name" type="String" />
			<description>
				通过名称获取属性的值。
			</description>
		</method>
		<method name="get_attributes" qualifiers="const">
			<return type="RuntimeAttribute[]" />
			<description>
				获取所有属性。
			</description>
		</method>
		<method name="get_manual_ticking" qualifiers="const">
			<return type="bool"/>
			<description>
				返回 `manual_ticking` 标志。
			</description>
		</method>
		<method name="remove_attribute">
			<return type="void" />
			<param index="0" name="p_attribute" type="AttributeBase" />
			<description>
				从容器中移除一个属性。
			</description>
		</method>
		<method name="remove_buff">
			<return type="void" />
			<param index="0" name="p_buff" type="AttributeBuff" />
			<description>
				从容器中移除一个增益效果。
			</description>
		</method>
		<method name="setup">
			<return type="void" />
			<description>
				设置容器。如果 [method _ready] 方法没有被调用，请在程序中调用此方法。
			</description>
		</method>
		<method name="set_manual_ticking">
			<return type="void" />
			<param index="0" name="p_manual_ticking" type="bool" />
			<description>
				设置 [manual_ticking] 布尔值。
			</description>
		</method>
		<method name="subtract_attribute_buffs_ticks">
			<return type="void" />
			<param index="0" name="p_tick" type="float" />
			<description>
				将传递的 p_tick 值减去容器中所有定时瞬态 [AttributeBuff] 实例的持续时间。
				适用于回合制游戏或处理程序化的重置/更新。
			</description>
		</method>
	</methods>
	<members>
		<member name="attribute_set" type="AttributeSet" setter="set_attribute_set" getter="get_attribute_set">
			属性的集合。
		</member>
		<member name="manual_ticking" type="bool" setter="set_manual_ticking" getter="get_manual_ticking">
			如果设置为 true，则每个 [AttributeBuff] 的持续时间将由你来处理。
		</member>
	</members>
	<signals>
		<signal name="attribute_changed">
			<param index="0" name="attribute" type="RuntimeAttributeBase" />
			<param index="1" name="previous_value" type="float" />
			<param index="2" name="new_value" type="float" />
			<description>
				当属性发生变化时触发。
			</description>
		</signal>
		<signal name="buff_applied">
			<param index="0" name="buff" type="RuntimeBuff" />
			<description>
				当增益效果被应用时触发。
			</description>
		</signal>
		<signal name="buff_dequed">
			<param index="0" name="buff" type="RuntimeBuff" />
			<description>
				当增益效果因过期而被出队时触发。
			</description>
		</signal>
		<signal name="buff_enqued">
			<param index="0" name="buff" type="RuntimeBuff" />
			<description>
				当增益效果被入队时触发。
			</description>
		</signal>
		<signal name="buff_removed">
			<param index="0" name="buff" type="RuntimeBuff" />
			<description>
				当增益效果被移除时触发。
			</description>
		</signal>
	</signals>
</class>